# Copy this file to .env and fill in real values before running `docker compose up`.

# Root password for the shared MySQL container (also used by its healthcheck).
MYSQL_ROOT_PASSWORD=changeme

# JWT signing secret used by task-user-service. Must be at least 32 bytes long for HS256.
JWT_SECRET=changeme-please-generate-a-random-32-byte-minimum-secret

# Application database credentials (used by task-user-service, task-service, task-submission-service).
DB_USER=root
DB_PASSWORD=changeme

# Activates each service's application-docker.yaml profile.
SPRING_PROFILES_ACTIVE=docker
